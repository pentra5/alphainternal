{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Alpha",
  "version": "1.0.0",
  "identifier": "com.alpha.internal",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "Alpha — Internal Work Management",
        "width": 1280,
        "height": 800,
        "minWidth": 1024,
        "minHeight": 680,
        "resizable": true,
        "fullscreen": false,
        "center": true,
        "decorations": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src 'self' http://localhost:* http://127.0.0.1:* https://*; img-src 'self' data: http://localhost:* http://127.0.0.1:* https://*; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDhBMjcxMUMxMjkxQ0UzQjIKUldTeTR4d3B3UkVuaXZCdy9PbG9NK0lwbHd6eVl2Qk52UjY2UkZsY1NHQ1FMOEJobjArWVlaREsK",
      "endpoints": [
        "https://github.com/pentra5/alphainternal/releases/latest/download/latest.json"
      ],
      "dialog": true
    }
  }
}
